{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.ts"
    },
    {
      "source": "/assets/(.*)",
      "destination": "client/dist/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "client/dist/index.html"
    }
  ]
}
